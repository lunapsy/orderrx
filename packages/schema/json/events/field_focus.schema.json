{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://orderrx.local/schema/events/field_focus.schema.json",
  "title": "FieldFocusEvent",
  "description": "input/textarea/select focus. 값 자체는 어떠한 형태로도 저장하지 않는다.",
  "allOf": [
    { "$ref": "../event_base.schema.json" },
    {
      "type": "object",
      "required": [
        "event_type",
        "field_selector",
        "field_name",
        "field_type",
        "field_autocomplete",
        "field_label_redacted",
        "input_length",
        "token_class",
        "is_sensitive",
        "sensitive_reason"
      ],
      "properties": {
        "event_type": { "const": "field_focus" },
        "field_selector": { "type": "string" },
        "field_name": {
          "type": "string",
          "description": "민감 패턴 매치 시 '[REDACTED]'."
        },
        "field_type": { "type": "string" },
        "field_autocomplete": { "type": ["string", "null"] },
        "field_label_redacted": { "type": ["string", "null"], "maxLength": 40 },
        "input_length": {
          "type": "integer",
          "minimum": -1,
          "description": "focus 시 0, blur 시 실제 길이. password 필드는 -1."
        },
        "token_class": {
          "type": "string",
          "enum": [
            "empty",
            "digits",
            "alpha_lower",
            "alpha_upper",
            "alpha_mixed",
            "alphanumeric",
            "korean",
            "korean_mixed",
            "email_like",
            "phone_like",
            "mixed_symbols",
            "blocked"
          ]
        },
        "is_sensitive": { "type": "boolean" },
        "sensitive_reason": { "type": ["string", "null"] }
      }
    }
  ]
}
