{
  "manifest_version": 3,
  "name": "OrderRx Training Track",
  "version": "0.3.0",
  "description": "참여 동의한 약국 테스터의 주문 사이트 workflow 학습 데이터 수집 도구. 등록한 사이트에서만 동작, 민감정보 자동 차단.",
  "minimum_chrome_version": "116",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "OrderRx Training Track"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
